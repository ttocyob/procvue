group {
   name: "procvue/panel/disk";
   min: 64 112;

   parts {
      part { 
         name: "disk_bg";
         type: IMAGE; 
         scale: 1;
         mouse_events: 0;

         description { 
            state: "default" 0.0;
            image.normal: "images/bg.png";
            image.border: 4 4 4 4;
            color_class: "/procvue/bg/panel";
         }
      }

// spacers
      part { 
         name: "disk_header_spacer";
         type: SPACER;
         scale: 1;

         description { 
            state: "default" 0.0;
            rel1 { to: "disk_bg"; relative: 0.0 0.0; offset: 0 0; }
            rel2 { to: "disk_bg"; relative: 1.0 0.0; offset: -1 15; }
            fixed: 0 1;
            offscale;
         }
      }

      part { 
         name: "rd_header_spacer";
         type: SPACER;
         scale: 1; 

         description { 
            state: "default" 0.0;
            rel1 { to: "disk_header_spacer"; relative: 0.0 1.0; offset: 0 0; }
            rel2 { to: "disk_bg"; relative: 1.0 0.0; offset: -1 31; }
            fixed: 0 1;
            offscale;
         }
      }

      part { 
         name: "rd_bar_spacer";
         type: SPACER;
         scale: 1;

         description { 
            state: "default" 0.0;
            rel1 { to: "rd_header_spacer"; relative: 0.0 1.0; offset: 0 0; }
            rel2 { to: "disk_bg"; relative: 1.0 0.0; offset: -1 47; }
            fixed: 0 1;
            offscale;
         }
      }

      part { 
         name: "rd_value_spacer";
         type: SPACER;
         scale: 1;

         description { 
            state: "default" 0.0;
            rel1 { to: "rd_bar_spacer"; relative: 0.0 1.0; offset: 0 0; }
            rel2 { to: "disk_bg"; relative: 1.0 0.0; offset: -1 63; }
            fixed: 0 1;
            offscale;
         }
      }

      part { 
         name: "wr_header_spacer";
         type: SPACER;
         scale: 1;

         description { 
            state: "default" 0.0;
            rel1 { to: "rd_value_spacer"; relative: 0.0 1.0; offset: 0 0; }
            rel2 { to: "disk_bg";  relative: 1.0 0.0; offset: -1 79; }
            fixed: 0 1;
            offscale;
         }
      }

      part { 
         name: "wr_bar_spacer";
         type: SPACER;
         scale: 1;

         description { 
            state: "default" 0.0;
            rel1 { to: "wr_header_spacer"; relative: 0.0 1.0; offset: 0 0; }
            rel2 { to: "disk_bg";   relative: 1.0 0.0; offset: -1 95; }
            fixed: 0 1;
            offscale;
         }
      }

      part { 
         name: "wr_value_spacer";
         type: SPACER;
         scale: 1;

         description { 
            state: "default" 0.0;
            rel1 { to: "wr_bar_spacer";  relative: 0.0 1.0; offset: 0 0; }
            rel2 { to: "disk_bg"; relative: 1.0 1.0; offset: -1 -1; }
            fixed: 0 1;
            offscale;
         }
      }

/*
      part { name: "disk_header-debug";
         type: RECT; scale: 1;
         description { state: "default" 0.0;
            rel1 { to: "disk_bg"; relative: 0.0 0.0; offset: 0 0; }
            rel2 { to: "disk_bg"; relative: 1.0 0.0; offset: -1 15; }
            fixed: 0 1; color: 0 255 0 100; offscale;
         }
      }
